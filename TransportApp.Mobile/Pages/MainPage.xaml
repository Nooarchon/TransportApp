<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:TransportApp.Mobile.PageModels"             
             xmlns:models="clr-namespace:TransportApp.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TransportApp.Mobile.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             Title="{Binding Today}">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="10">

        <!-- Search Section -->
        <VerticalStackLayout Grid.Row="0" Spacing="5">
            <Label Text="Transport" FontSize="28" FontAttributes="Bold" />

            <SearchBar Placeholder="Search..."
           Text="{Binding SearchText}"
           SearchCommand="{Binding SearchStopsCommand}" />
        </VerticalStackLayout>

        <!-- Main Content (Schedule) -->
        <RefreshView Grid.Row="1" 
                     IsRefreshing="{Binding IsRefreshing}" 
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Departures}">
                <CollectionView.Header>
                    <Label Text="Upcoming Departures" Margin="0,10" FontAttributes="Bold" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:StopDeparture">
                        <Border Margin="0,5" Padding="15" StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, Path=GoToStopDetailsCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="50, *, Auto">
                                <Label Text="{Binding route_short_name}" FontAttributes="Bold" TextColor="#512BD4" VerticalOptions="Center"/>
                                <Label Grid.Column="1" Text="{Binding trip_headsign}" VerticalOptions="Center" Margin="10,0"/>
                                <Label Grid.Column="2" Text="{Binding arrival_time}" VerticalOptions="Center" FontAttributes="Bold"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Search Results Dropdown -->
        <Border Grid.Row="1" 
                VerticalOptions="Start" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#303030}"
                Stroke="#512BD4"
                StrokeThickness="1"
                ZIndex="10"
                IsVisible="{Binding IsSuggestionsVisible}"
                Margin="5,0"
                MaximumHeightRequest="300"
                StrokeShape="RoundRectangle 0,0,10,10">
            <CollectionView ItemsSource="{Binding FoundStops}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Stop">
                        <Grid Padding="15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, Path=SelectStopCommand}"
                                    CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                            <Label Text="{Binding stop_name}" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <!-- Search Loading Indicator -->
        <ActivityIndicator Grid.Row="1" 
                           IsRunning="{Binding IsSearching}" 
                           IsVisible="{Binding IsSearching}"
                           HorizontalOptions="Center" 
                           VerticalOptions="Start" 
                           Margin="0,50" />
    </Grid>
</ContentPage>