<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:TransportApp.Mobile.PageModels"
             xmlns:models="clr-namespace:TransportApp.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TransportApp.Mobile.Pages.RoutePlannerPage"
             x:DataType="pageModels:RoutePlannerPageModel"
             Title="Planner">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Where are we going?" FontSize="28" FontAttributes="Bold" Margin="0,0,0,10"/>

            <!-- ОТПРАВНАЯ ТОЧКА (FROM) -->
            <Label Text="From" FontSize="14" TextColor="Gray"/>
            <Grid RowDefinitions="Auto, Auto">
                <Frame Padding="5,0" HasShadow="False" BorderColor="LightGray" CornerRadius="8">
                    <SearchBar Placeholder="Origin (e.g. Praha...)" 
                               Text="{Binding OriginText}"
                               HeightRequest="45">
                        <SearchBar.Behaviors>
                            <toolkit:EventToCommandBehavior 
                                EventName="TextChanged" 
                                Command="{Binding SearchOriginCommand}" />
                        </SearchBar.Behaviors>
                    </SearchBar>
                </Frame>

                <Frame Grid.Row="1"
                       IsVisible="{Binding IsOriginSuggestionsVisible}"
                       BackgroundColor="#252525"
                       BorderColor="Gray"
                       Padding="0"
                       HasShadow="True"
                       HeightRequest="200"
                       ZIndex="10">
                    <CollectionView ItemsSource="{Binding OriginSuggestions}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Stop">
                                <Grid Padding="15" BackgroundColor="Transparent">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:RoutePlannerPageModel}}, Path=SelectOriginCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <!-- Важно: проверьте соответствие имени поля stop_name в модели Stop -->
                                    <Label Text="{Binding stop_name}" TextColor="White" FontSize="16" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>
            </Grid>

            <!-- ТОЧКА НАЗНАЧЕНИЯ (TO) -->
            <Label Text="To" FontSize="14" TextColor="Gray" Margin="0,10,0,0"/>
            <Grid RowDefinitions="Auto, Auto">
                <Frame Padding="5,0" HasShadow="False" BorderColor="LightGray" CornerRadius="8">
                    <SearchBar Placeholder="Destination (e.g. Kolín...)" 
                               Text="{Binding DestinationText}"
                               HeightRequest="45">
                        <SearchBar.Behaviors>
                            <toolkit:EventToCommandBehavior 
                                EventName="TextChanged" 
                                Command="{Binding SearchDestinationCommand}" />
                        </SearchBar.Behaviors>
                    </SearchBar>
                </Frame>

                <Frame Grid.Row="1"
                       IsVisible="{Binding IsDestinationSuggestionsVisible}"
                       BackgroundColor="#252525"
                       BorderColor="Gray"
                       Padding="0"
                       HasShadow="True"
                       HeightRequest="200"
                       ZIndex="10">
                    <CollectionView ItemsSource="{Binding DestinationSuggestions}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Stop">
                                <Grid Padding="15" BackgroundColor="Transparent">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:RoutePlannerPageModel}}, Path=SelectDestinationCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="{Binding stop_name}" TextColor="White" FontSize="16" VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Frame>
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsSearching}" IsVisible="{Binding IsSearching}" HeightRequest="40" />

            <Button Text="Find Route" 
                    Command="{Binding FindRouteCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="25"
                    Margin="0,20,0,0" />

            <!-- РЕЗУЛЬТАТ МАРШРУТА -->
            <CollectionView ItemsSource="{Binding CalculatedRoute}" Margin="0,10">
                <CollectionView.Header>
                    <Label Text="Recommended Route:" 
                           FontAttributes="Bold" 
                           FontSize="18"
                           Margin="0,10"
                           TextColor="White"
                           IsVisible="{Binding CalculatedRoute.Count}" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Stop">
                        <Grid ColumnDefinitions="30, *" Padding="5">
                            <Ellipse Fill="Green" WidthRequest="10" HeightRequest="10" VerticalOptions="Center" HorizontalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding stop_name}" TextColor="White" FontSize="16" VerticalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>