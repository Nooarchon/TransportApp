<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:TransportApp.Mobile.PageModels"
             xmlns:models="clr-namespace:TransportApp.Mobile.Models"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="TransportApp.Mobile.Pages.RoutePlannerPage"
             x:DataType="pageModels:RoutePlannerPageModel"
             x:Name="ThisPage"
             Title="Planner">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Where are we going?" FontSize="28" FontAttributes="Bold" Margin="0,0,0,10" />

            <!-- СЕКЦИЯ ОТКУДА (FROM) -->
            <VerticalStackLayout Spacing="5">
                <Label Text="From" FontSize="14" TextColor="Gray" />

                <Border Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="5,0">
                    <SearchBar Placeholder="Origin..."
                               Text="{Binding OriginText}"
                               SearchCommand="{Binding SearchOriginCommand}">
                        <SearchBar.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged" Command="{Binding SearchOriginCommand}" />
                        </SearchBar.Behaviors>
                    </SearchBar>
                </Border>

                <!-- Список подсказок (БЕЗ TranslationY) -->
                <Border IsVisible="{Binding IsOriginSuggestionsVisible}"
                        BackgroundColor="#252525"
                        Stroke="Gray"
                        StrokeShape="RoundRectangle 8"
                        MaximumHeightRequest="200">
                    <CollectionView ItemsSource="{Binding OriginSuggestions}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Stop">
                                <!-- ContentView помогает ловить нажатия на Android/Windows -->
                                <ContentView>
                                    <Border Padding="15" BackgroundColor="#252525">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding BindingContext.SelectOriginCommand, Source={x:Reference ThisPage}}" 
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding stop_name}" TextColor="White" FontSize="16" InputTransparent="True" />
                                    </Border>
                                </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </VerticalStackLayout>

            <!-- СЕКЦИЯ КУДА (TO) -->
            <VerticalStackLayout Spacing="5">
                <Label Text="To" FontSize="14" TextColor="Gray" Margin="0,10,0,0" />

                <Border Stroke="LightGray" StrokeShape="RoundRectangle 8" Padding="5,0">
                    <SearchBar Placeholder="Destination..."
                               Text="{Binding DestinationText}"
                               SearchCommand="{Binding SearchDestinationCommand}">
                        <SearchBar.Behaviors>
                            <toolkit:EventToCommandBehavior EventName="TextChanged" Command="{Binding SearchDestinationCommand}" />
                        </SearchBar.Behaviors>
                    </SearchBar>
                </Border>

                <Border IsVisible="{Binding IsDestinationSuggestionsVisible}"
                        BackgroundColor="#252525"
                        Stroke="Gray"
                        StrokeShape="RoundRectangle 8"
                        MaximumHeightRequest="200">
                    <CollectionView ItemsSource="{Binding DestinationSuggestions}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Stop">
                                <ContentView>
                                    <Border Padding="15" BackgroundColor="#252525">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding BindingContext.SelectDestinationCommand, Source={x:Reference ThisPage}}" 
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Label Text="{Binding stop_name}" TextColor="White" FontSize="16" InputTransparent="True" />
                                    </Border>
                                </ContentView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </VerticalStackLayout>

            <Button Text="Find Route"
                    Command="{Binding FindRouteCommand}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="25"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>