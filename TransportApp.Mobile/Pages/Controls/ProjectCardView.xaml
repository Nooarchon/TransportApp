<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TransportApp.Mobile.Models"
             x:Class="TransportApp.Mobile.Pages.Controls.ProjectCardView"
             x:DataType="models:Project">

    <Frame CornerRadius="10" HasShadow="True" Margin="5" Padding="10">
        <VerticalStackLayout Spacing="5">
            <Label Text="{Binding Name}" 
                   FontSize="18" 
                   FontAttributes="Bold" />
            <Label Text="{Binding Description}" 
                   FontSize="14" 
                   TextColor="Gray" />
        </VerticalStackLayout>
    </Frame>

</ContentView>